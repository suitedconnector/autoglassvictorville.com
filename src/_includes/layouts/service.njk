---
layout: layouts/base.njk
---

<section class="hero" style="background-image: url(/assets/honda-civic-broken-windshield.jpg); background-size: cover; background-position: center; position: relative;">
  <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4);"></div>
  <div class="container" style="position: relative; z-index: 1;">
    <h1>{{ title }}</h1>
    <p class="hero-subtitle">{{ subtitle }}</p>
    <a href="/contact/" class="cta-button">Get Free Quote</a>
  </div>
</section>

<section class="content-section">
  <div class="container">
    <div class="service-content">
      {{ content | safe }}
    </div>
  </div>
</section>

<section class="related-services">
  <div class="container">
    <h2>Other Services</h2>
    <div class="service-grid">
      {% for service in site.services %}
      {% if service.slug !== page.fileSlug %}
      <a href="{{ service.url }}" class="service-card">
        <h3>{{ service.name }}</h3>
        <p>Learn more →</p>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
